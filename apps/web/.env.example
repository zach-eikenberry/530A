# Public (client-visible) config — set as GitHub Actions variables for CI builds.
# Sentry error tracking; the DSN is public by design (ingest-only).
PUBLIC_SENTRY_DSN=
# Cloudflare Web Analytics beacon token (dashboard → Analytics → Web Analytics).
PUBLIC_CF_BEACON_TOKEN=
# Anonymized event beacon endpoint (apps/workers 530a-events). Unset = disabled.
PUBLIC_EVENTS_ENDPOINT=

---
import { CANONICAL_LINKS, faqs, RULES_VERIFIED_AT } from '@530a/config'
import Base from '../layouts/Base.astro'

const title = '530A Account FAQ — eligibility, caps, taxes, withdrawals'
const description =
  'Plain-English answers about 530A “Trump Accounts”: who qualifies for the $1,000 seed, contribution limits, tax treatment, and what happens at 18.'

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}
---

<Base title={title} description={description} path="/faq" jsonLd={[faqLd]} ogType="article">
  <section class="section-tight" style="background: linear-gradient(180deg, var(--navy-800), var(--navy-900)); color: #fff;">
    <div class="container">
      <span class="eyebrow" style="color: var(--gold-400);">FAQ</span>
      <h1 class="mt-2" style="color: #fff;">Questions about 530A accounts</h1>
      <p class="lead mt-2" style="color: #b9c9e0; max-width: 66ch;">
        Straight answers grounded in the statute and IRS guidance — rules verified as of
        {RULES_VERIFIED_AT} against the
        <a href={CANONICAL_LINKS.statute} style="color: var(--gold-400);">statute</a>,
        <a href={CANONICAL_LINKS.irsNotice} style="color: var(--gold-400);">IRS Notice 2025-68</a>,
        and the
        <a href={CANONICAL_LINKS.crsOverview} style="color: var(--gold-400);">CRS overview</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container container-narrow">
      <div class="accordion">
        {faqs.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <div class="acc-body">
              <p>{f.a}</p>
            </div>
          </details>
        ))}
      </div>

      <p class="mt-4">
        Keep reading: how a 530A <a href="/compare">compares with 529, custodial, and Roth
        accounts</a>, the exact <a href="/methodology">math behind every projection</a>, and the
        <a href="/open-account">step-by-step guide to opening an account</a>.
      </p>

      <div class="cta-band mt-4">
        <h2 style="font-size: 1.5rem;">Ready to see your numbers?</h2>
        <p>The calculator is free and runs entirely in your browser.</p>
        <div class="cta-actions">
          <a class="btn btn-gold btn-lg" href="/">Open the calculator</a>
          <a class="btn btn-ghost btn-lg" href="/model" style="background: transparent; color: #fff; border-color: rgba(255,255,255,.35);">Advanced Model</a>
        </div>
      </div>
    </div>
  </section>
</Base>

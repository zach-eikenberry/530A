---
import AdvancedModel from '../components/AdvancedModel'
import Base from '../layouts/Base.astro'

const title = 'Advanced 530A Model — ranges, contributors, comparisons'
const description =
  'Model a 530A account in full: multiple contributors, honest Monte-Carlo ranges, fees, inflation, the at-18 tax branch, and side-by-side comparisons. Free, private, no login.'
---

<Base title={title} description={description} path="/model">
  <section style="padding: 2rem 0 1rem;">
    <h1>Advanced Model</h1>
    <p class="muted">
      Every control recalculates 5,000 simulated markets on your device. The whole scenario lives
      in the shareable link — nothing is uploaded or stored.
    </p>
  </section>
  {/* client:only (island reads window.location.search). The wrapper reserves
      a viewport of height so hydration never shifts visible layout (CLS);
      the island removes the skeleton on mount. */}
  <div style="min-height: 100vh;">
    <div id="model-skeleton" class="card" aria-hidden="true">
      <p class="muted" style="margin: 0;">Loading the model…</p>
    </div>
    <AdvancedModel client:only="preact" />
  </div>
</Base>

---
import ModelPreview from '../components/ModelPreview'
import Base from '../layouts/Base.astro'

const title = 'Advanced Model — 530A Model'
const description =
  'Reconstruct and inspect any shared 530A scenario. Milestone projections in today’s dollars, honest assumptions, no login.'
---

<Base title={title} description={description} path="/model">
  <section style="padding: 2rem 0 1rem;">
    <h1>Advanced Model</h1>
    <p class="muted">
      Scenarios are stateless: everything needed to reproduce this projection is encoded in the
      link itself.
    </p>
  </section>
  {/* client:only — the island reads window.location.search, so no prerender */}
  <ModelPreview client:only="preact" />
</Base>

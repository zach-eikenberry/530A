---
import { CANONICAL_LINKS, CANONICAL_ORIGIN, RULES_VERIFIED_AT } from '@530a/config'
import Widget from '../components/Widget'
import Base from '../layouts/Base.astro'

const title = '530A Model — free calculator for 530A "Trump Accounts"'
const description =
  'See what your child’s 530A account could be worth at 18, 36, or 72. Free, private, no login — every eligible child born 2025–2028 gets a $1,000 federal seed.'

const webAppLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: '530A Model',
  url: CANONICAL_ORIGIN,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description,
}

const howToSteps = [
  {
    name: 'Check eligibility',
    text: 'U.S.-citizen children with a Social Security number qualify; children born January 1, 2025 through December 31, 2028 also receive a one-time $1,000 federal seed.',
  },
  {
    name: 'Open the account',
    text: "Open an account at trumpaccounts.gov, with IRS Form 4547, or through the Treasury's Trump Accounts application.",
  },
  {
    name: 'Contribute (from July 4, 2026)',
    text: 'Contribute up to $5,000 per child per year from any source; employers may add up to $2,500 within that cap. Funds grow tax-deferred in a low-cost S&P 500 index fund.',
  },
]

const howToLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to open a 530A (Trump Account) for your child',
  step: howToSteps.map((s) => ({ '@type': 'HowToStep', name: s.name, text: s.text })),
}
---

<Base title={title} description={description} path="/" jsonLd={[webAppLd, howToLd]}>
  <section class="hero">
    <div class="hero-flag"></div>
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">Free · Open source · No tracking</span>
        <h1 class="mt-2">What could your child's<br />530A account be worth?</h1>
        <p class="lead mt-3">
          The <strong>530A account</strong> — nicknamed a "Trump Account" — is a new
          tax-advantaged investment account for children created by the One Big Beautiful Bill Act
          of 2025. Move the sliders to see how small, steady contributions could compound over a
          lifetime.
        </p>
        <div class="flex gap-2 wrap mt-4">
          <a class="btn btn-gold btn-lg" href="#calc">Run your numbers</a>
          <a class="btn btn-ghost btn-lg" href="/model">Try the Advanced Model</a>
        </div>
        <div class="mt-4" style="color: #90a3c2; font-size: 0.86rem; max-width: 46ch;">
          Independent educational tool. Not affiliated with, or endorsed by, the U.S. government
          or trumpaccounts.gov.
        </div>
      </div>
      <Widget client:load />
    </div>
  </section>

  <section class="section-tight" style="background: var(--paper); border-bottom: 1px solid var(--line);">
    <div class="container">
      <div class="trust-bar">
        {[
          'Runs 100% in your browser',
          'No login, no cookies, no data collected',
          'Open-source math, verified to the cent',
          'Built on primary sources',
        ].map((t) => (
          <span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            {t}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="center" style="max-width: 64ch; margin-inline: auto;">
        <span class="eyebrow">The basics</span>
        <h2 class="mt-2">A retirement head-start, opened the year your child is born</h2>
        <p class="lead mt-2" style="margin-inline: auto;">
          Think of a 530A as an IRA that starts decades early. Money is invested in a low-cost
          U.S. stock index fund, grows tax-deferred, and belongs to your child when they turn 18.
        </p>
      </div>
      <div class="grid grid-4 mt-4">
        <div class="card feature card-hover">
          <div class="ficon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
          </div>
          <h3>$1,000 to start</h3>
          <p>
            Children who are U.S. citizens born Jan 1, 2025 – Dec 31, 2028 get a one-time $1,000
            federal contribution to seed the account.
          </p>
        </div>
        <div class="card feature card-hover">
          <div class="ficon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"></path><path d="M7 14l4-4 3 3 5-6"></path></svg>
          </div>
          <h3>Grows with the market</h3>
          <p>
            Funds are invested in low-fee index funds tracking primarily U.S. companies — the same
            engine behind long-term retirement growth.
          </p>
        </div>
        <div class="card feature card-hover">
          <div class="ficon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="M3 10h18"></path></svg>
          </div>
          <h3>Up to $5,000 a year</h3>
          <p>
            Family, friends, and even employers can contribute up to $5,000 combined per child
            each year — after tax, indexed to inflation after 2027.
          </p>
        </div>
        <div class="card feature card-hover">
          <div class="ficon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3>Theirs at 18</h3>
          <p>
            No withdrawals during childhood. At 18 the account follows Traditional IRA rules and
            your child takes the wheel.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--paper); border-block: 1px solid var(--line);">
    <div class="container container-narrow">
      <span class="eyebrow">Getting started</span>
      <h2 class="mt-2">How to open a 530A for your child</h2>
      <div class="steps mt-4">
        {howToSteps.map((s) => (
          <div class="step">
            <div class="num"></div>
            <div>
              <h3>{s.name}</h3>
              <p>{s.text}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="mt-3">
        Full walkthrough on the <a href="/open-account">How to Open</a> page, and every claim
        traces to a <a href="/resources">primary source</a> — statute, IRS guidance, CRS — rules
        verified as of {RULES_VERIFIED_AT}. See also the
        <a href={CANONICAL_LINKS.statute}>statute itself</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-band">
        <h2>Why trust these numbers?</h2>
        <p class="mt-2">
          The math is open source and tested against an independent reference implementation to
          the cent. Every projection is labeled for what it is: an estimate with an honest range,
          never a promise. Your inputs never leave your device.
        </p>
        <div class="cta-actions">
          <a class="btn btn-gold btn-lg" href="/methodology">Read the methodology</a>
          <a class="btn btn-ghost btn-lg" href="/why-free">Why is this free?</a>
        </div>
      </div>
    </div>
  </section>
</Base>

---
import { CANONICAL_ORIGIN, RULES_VERIFIED_AT } from '@530a/config'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  /** Path starting with /, used for the canonical URL. */
  path: string
  /** Extra JSON-LD blocks (already-serializable objects). */
  jsonLd?: object[]
}

const { title, description, path, jsonLd = [] } = Astro.props
const canonical = `${CANONICAL_ORIGIN}${path === '/' ? '/' : path.replace(/\/$/, '')}`

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '530A Model',
  url: CANONICAL_ORIGIN,
  description:
    'Free, privacy-first scenario-planning calculator for 530A custodial retirement accounts.',
}

const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="530A Model" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    {jsonLd.map((block) => <script type="application/ld+json" set:html={JSON.stringify(block)} />)}
  </head>
  <body>
    <script src="../scripts/sentry-init.ts"></script>
    <a class="skip-link" href="#main">Skip to content</a>
    <header style="border-bottom: 1px solid var(--border);">
      <nav
        style="max-width: 46rem; margin: 0 auto; padding: 0.9rem 1.25rem; display: flex; gap: 1.1rem; align-items: baseline; flex-wrap: wrap;"
        aria-label="Main"
      >
        <a href="/" style="font-weight: 700; text-decoration: none; color: var(--trust-blue-dark); font-size: 1.05rem;"
          >530A<span style="color: var(--growth-green);">Model</span></a
        >
        <a href="/model" class="muted" style="text-decoration: none;">Advanced Model</a>
        <a href="/faq" class="muted" style="text-decoration: none;">FAQ</a>
        <a href="/resources" class="muted" style="text-decoration: none;">Resources</a>
        <a href="/why-free" class="muted" style="text-decoration: none;">Why free?</a>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer style="border-top: 1px solid var(--border); background: var(--surface);">
      <div style="max-width: 46rem; margin: 0 auto; padding: 1.5rem 1.25rem;" class="muted">
        <p>
          <strong>Estimates only — not financial, tax, or legal advice.</strong> Market projections
          are probabilistic ranges, not guarantees. Verify rules with the primary sources on our
          <a href="/resources">Resources</a> page before making decisions.
        </p>
        <p>
          Rules verified as of {RULES_VERIFIED_AT} · <a href="/terms">Terms</a> ·
          <a href="/privacy">Privacy</a> · No login, no cookies, no data collected.
        </p>
      </div>
    </footer>
    {beaconToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: beaconToken })}
      />
    )}
  </body>
</html>

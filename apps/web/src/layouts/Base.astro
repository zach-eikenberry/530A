---
import { CANONICAL_ORIGIN, RULES_VERIFIED_AT } from '@530a/config'
import { GITHUB_URL, ORG_ID, WEBSITE_ID } from '../lib/seo'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  /** Path starting with /, used for the canonical URL and nav highlighting. */
  path: string
  /** Extra JSON-LD blocks (already-serializable objects). */
  jsonLd?: object[]
  /** OpenGraph type; 'article' also emits article:modified_time (rules-verified date). */
  ogType?: 'website' | 'article'
  /** Keep the page out of search indexes (admin, 404). */
  noindex?: boolean
}

const { title, description, path, jsonLd = [], ogType = 'website', noindex = false } = Astro.props
const canonical = `${CANONICAL_ORIGIN}${path === '/' ? '/' : path.replace(/\/$/, '')}`

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': ORG_ID,
  name: '530A Model',
  url: CANONICAL_ORIGIN,
  logo: `${CANONICAL_ORIGIN}/assets/img/mark.svg`,
  description:
    'Free, privacy-first scenario-planning calculator for 530A custodial retirement accounts.',
  sameAs: [GITHUB_URL],
}

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': WEBSITE_ID,
  name: '530A Model',
  url: CANONICAL_ORIGIN,
  description:
    'Free, privacy-first scenario-planning calculator for 530A custodial retirement accounts.',
  inLanguage: 'en',
  publisher: { '@id': ORG_ID },
}

// Breadcrumb labels for indexable subpages (admin/404 intentionally absent).
const crumbLabels: Record<string, string> = {
  '/model': 'Advanced Model',
  '/compare': 'Compare accounts',
  '/open-account': 'How to open',
  '/faq': 'FAQ',
  '/resources': 'Resources',
  '/methodology': 'Methodology',
  '/pledges': 'Pledges & gifts',
  '/api': 'API & MCP',
  '/why-free': 'Why free',
  '/terms': 'Terms',
  '/privacy': 'Privacy',
}
const crumbLabel = crumbLabels[path.replace(/\/$/, '')]
const breadcrumbLd = crumbLabel
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${CANONICAL_ORIGIN}/` },
        { '@type': 'ListItem', position: 2, name: crumbLabel, item: canonical },
      ],
    }
  : null

const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN

const nav = [
  { href: '/model', label: 'Advanced Model' },
  { href: '/compare', label: '529 vs 530A' },
  { href: '/open-account', label: 'How to Open' },
  { href: '/faq', label: 'FAQ' },
  { href: '/resources', label: 'Resources' },
]
const current = (href: string) => (path === href ? 'page' : undefined)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="530A Pledges & Gifts"
      href={`${CANONICAL_ORIGIN}/pledges.xml`}
    />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="530A Model" />
    <meta property="og:image" content={`${CANONICAL_ORIGIN}/assets/img/og.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="530A Model — free 530A account calculator" />
    {ogType === 'article' && (
      <meta property="article:modified_time" content={RULES_VERIFIED_AT} />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${CANONICAL_ORIGIN}/assets/img/og.png`} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    {breadcrumbLd && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    )}
    <slot name="head" />
    {jsonLd.map((block) => <script type="application/ld+json" set:html={JSON.stringify(block)} />)}
    <script is:inline>
      // Theme init before first paint (local-only preference, not tracking)
      ;(() => {
        let t = null
        try {
          t = localStorage.getItem('theme')
        } catch {}
        if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        document.documentElement.setAttribute('data-theme', t)
      })()
    </script>
    <script src="../scripts/sentry-init.ts"></script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="container nav">
        <a class="brand" href="/">
          <img class="mark" src="/assets/img/mark.svg" alt="" width="34" height="34" />
          <span>530A&nbsp;Model</span>
        </a>
        <button
          type="button"
          class="nav-toggle"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="navLinks"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"></path></svg>
        </button>
        <nav class="nav-links" id="navLinks" aria-label="Primary">
          {nav.map((item) => (
            <a href={item.href} aria-current={current(item.href)}>
              {item.label}
            </a>
          ))}
          <div class="nav-actions">
            <button type="button" class="theme-toggle" aria-label="Toggle theme"></button>
            <a class="btn btn-gold btn-sm" href="/open-account">Open an account</a>
          </div>
        </nav>
      </div>
    </header>

    <div
      id="first-use-notice"
      hidden
      style="position: fixed; inset: auto 0 0 0; z-index: 70; pointer-events: none;"
    >
      <div class="container" style="padding-bottom: 14px; pointer-events: auto;">
        <div class="callout-info callout" style="display: flex; gap: 12px; align-items: baseline; box-shadow: var(--shadow-lg); border-radius: var(--radius-sm); background: var(--paper);">
          <span
            >Quick note: everything here is an educational estimate, not financial advice. Ranges
            are possibilities, not promises.</span
          >
          <button
            type="button"
            id="first-use-dismiss"
            class="btn btn-ghost btn-sm"
            style="margin-left: auto; white-space: nowrap;">Got it</button
          >
        </div>
      </div>
    </div>
    <script>
      // One-time first-use notice (§8): shown until dismissed, never again after.
      const KEY = '530a-notice-dismissed'
      const notice = document.getElementById('first-use-notice')
      try {
        if (notice && !localStorage.getItem(KEY)) {
          notice.hidden = false
          document.getElementById('first-use-dismiss')?.addEventListener('click', () => {
            localStorage.setItem(KEY, '1')
            notice.hidden = true
          })
        }
      } catch {
        /* storage unavailable → leave hidden */
      }
    </script>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a class="brand" href="/" style="color: #fff;">
              <img class="mark" src="/assets/img/mark.svg" alt="" width="34" height="34" />
              <span>530A&nbsp;Model</span>
            </a>
            <p>
              A free, open-source projection tool for 530A accounts. Runs entirely in your
              browser — no login, no cookies, no data collected.
            </p>
          </div>
          <div>
            <div class="fh">Tools</div>
            <a href="/">Quick calculator</a>
            <a href="/model">Advanced Model</a>
            <a href="/api">API &amp; MCP</a>
          </div>
          <div>
            <div class="fh">Learn</div>
            <a href="/pledges">Pledges &amp; gifts</a>
            <a href="/compare">529 vs 530A</a>
            <a href="/open-account">How to open one</a>
            <a href="/faq">FAQ</a>
            <a href="/methodology">Methodology</a>
          </div>
          <div>
            <div class="fh">Trust</div>
            <a href="/resources">Primary sources</a>
            <a href="/why-free">Why it's free</a>
            <a href="/terms">Terms</a>
            <a href="/privacy">Privacy</a>
          </div>
        </div>
        <div class="footer-bottom">
          <span>Rules verified as of {RULES_VERIFIED_AT} · Estimates only — not financial advice.</span>
          <span>© <span data-year></span> 530A Model</span>
        </div>
        <p class="footer-disclaimer">
          Independent educational tool. Not affiliated with, or endorsed by, the U.S. government,
          the IRS, or trumpaccounts.gov. Market projections are probabilistic ranges, not
          guarantees — verify rules with the primary sources on our Resources page before making
          decisions.
        </p>
      </div>
    </footer>

    <script>
      // Theme toggle + mobile nav + footer year (no analytics, no third parties)
      const root = document.documentElement
      const moon =
        '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>'
      const sun =
        '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>'
      const paint = () => {
        const dark = root.getAttribute('data-theme') === 'dark'
        for (const b of document.querySelectorAll('.theme-toggle')) {
          b.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme')
          b.innerHTML = dark ? sun : moon
        }
      }
      paint()
      document.addEventListener('click', (e) => {
        const target = e.target as Element
        if (target.closest('.theme-toggle')) {
          const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'
          root.setAttribute('data-theme', next)
          try {
            localStorage.setItem('theme', next)
          } catch {}
          paint()
        }
        const nt = target.closest('.nav-toggle')
        const links = document.getElementById('navLinks')
        if (nt && links) {
          const open = links.classList.toggle('open')
          nt.setAttribute('aria-expanded', open ? 'true' : 'false')
        }
        if (target.closest('.nav-links a') && links) links.classList.remove('open')
      })
      for (const el of document.querySelectorAll('[data-year]')) {
        el.textContent = String(new Date().getFullYear())
      }
    </script>
    {beaconToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: beaconToken })}
      />
    )}
  </body>
</html>
